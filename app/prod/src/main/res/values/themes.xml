<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="CustomTheme" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">#FFFFFF</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowBackground">@color/primary</item>
    </style>

    <style name="Theme.ExampleApp.SplashScreen" parent="Theme.SplashScreen">
        <item name="windowSplashScreenAnimatedIcon">@drawable/logo_splash_200</item>
        <item name="windowSplashScreenBackground">@color/primary</item>
        <item name="postSplashScreenTheme">@style/CustomTheme</item>
        <item name="windowSplashScreenAnimationDuration">1000</item>
    </style>
</resources>